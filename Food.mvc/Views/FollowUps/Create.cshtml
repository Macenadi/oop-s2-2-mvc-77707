@model Food.domain.Models.FollowUp

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>FollowUp</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label class="control-label">Inspection</label>
                <select asp-for="InspectionId" class="form-control" asp-items="ViewBag.InspectionId" id="inspectionSelect"></select>
                <span asp-validation-for="InspectionId" class="text-danger"></span>
            </div>

            <div id="inspectionInfo" class="alert alert-info mt-2">
                Select an inspection to see information here.
            </div>

            <div class="form-group">
                <label asp-for="DueDate" class="control-label"></label>
                <input asp-for="DueDate" class="form-control" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control">
                    <option value="">-- Select Status --</option>
                    <option value="Open">Open</option>
                    <option value="Closed">Closed</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ClosedDate" class="control-label"></label>
                <input asp-for="ClosedDate" class="form-control" />
                <span asp-validation-for="ClosedDate" class="text-danger"></span>
            </div>

            <div class="form-group mt-2">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const select = document.getElementById("inspectionSelect");
            const infoBox = document.getElementById("inspectionInfo");
            const inspections = @Html.Raw(ViewBag.InspectionDetails);

            function updateInspectionInfo() {
                const selectedId = parseInt(select.value);

                if (!selectedId) {
                    infoBox.innerHTML = "Select an inspection to see information here.";
                    return;
                }

                const selectedInspection = inspections.find(i => i.Id === selectedId);

                if (selectedInspection) {
                    infoBox.innerHTML = `
                        <strong>Premise:</strong> ${selectedInspection.PremiseName}<br />
                        <strong>Inspection Date:</strong> ${selectedInspection.InspectionDate}<br />
                        <strong>Score:</strong> ${selectedInspection.Score}<br />
                        <strong>Outcome:</strong> ${selectedInspection.Outcome}<br />
                        <strong>Notes:</strong> ${selectedInspection.Notes}
                    `;
                }
                else {
                    infoBox.innerHTML = "Select an inspection to see information here.";
                }
            }

            select.addEventListener("change", updateInspectionInfo);
            updateInspectionInfo();
        });
    </script>
}