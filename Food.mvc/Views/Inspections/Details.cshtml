@model Food.domain.Models.Inspection

@{
    ViewData["Title"] = "Details";
    var relatedInspections = ViewBag.RelatedInspections as List<Food.domain.Models.Inspection>;
}

<h1>Details</h1>

<div>
    <h4>Inspection</h4>
    <hr />
    <div class="p-3 rounded" style="background-color:#f7fbff;">
        <dl class="row mb-0">

        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Premise)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Premise.Address)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.InspectionDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.InspectionDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Score)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Score)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Outcome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Outcome)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Notes)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Notes)
        </dd>
    </dl>
</div>


@if (relatedInspections != null && relatedInspections.Any())
{
    <hr />
    <h4>Other Inspections for the same Premise</h4>

    <table class="table">
        <thead>
            <tr>
                <th>Inspection Date</th>
                <th>Score</th>
                <th>Outcome</th>
                <th>Notes</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in relatedInspections)
            {
                <tr>
                    <td>@item.InspectionDate.ToShortDateString()</td>
                    <td>@item.Score</td>
                    <td>@item.Outcome</td>
                    <td>@item.Notes</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
